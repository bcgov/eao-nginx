# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Zone definitions live here (http context — this file is included from nginx.conf
# inside its http {} block via `include /etc/nginx/conf.d/*.conf`).
# $binary_remote_addr is more compact than $remote_addr (4/16 bytes vs string).
# Zone sizes: 10m ≈ 80k states — adequate for gov-scale traffic.
limit_req_zone  $binary_remote_addr zone=api_general:10m rate=30r/s;
limit_req_zone  $binary_remote_addr zone=api_search:10m  rate=10r/s;
limit_req_zone  $binary_remote_addr zone=analytics:5m    rate=20r/s;
limit_conn_zone $binary_remote_addr zone=conn_per_ip:10m;

# Respond 429 Too Many Requests (not default 503) and log at warn not error
limit_req_status  429;
limit_conn_status 429;
limit_req_log_level  warn;
limit_conn_log_level warn;

# Ajax
server {
  listen       8080;
  server_name  ${NGINX__AJAX__SERVER_NAME};

  return 301 https://${NGINX__AJAX__REDIRECT};
}

#EPIC application server
server {
  listen       8080 default_server;
  server_name  ${NGINX__EPIC__SERVER_NAME};

  # Allows non-standard headers like SMGOV_USERGUID
  ignore_invalid_headers off;

  # Limit concurrent TCP connections per IP across all locations in this server block
  limit_conn conn_per_ip 50;

  # 172.16.0.0/12 is the entire addressable space in the cluster
  #set_real_ip_from  172.51.0.0/22;
  #set_real_ip_from  172.51.4.0/22;
  #real_ip_header    X-Forwarded-For;

  location / {
    # proxy all traffic to this URL,
    # note the trailing slash strips out the /proxy path on
    # the request to the upstream server

    proxy_pass ${NGINX__EPIC__PROXY__ROOT};

    # Ensure HTTP get passed thru
    proxy_pass_request_headers on;

    # its helpful to cache these responses
    proxy_cache globalcache;

    # Deploy-time configurable
    ${HTTP_BASIC}
  }

  location /public {
    # proxy all traffic to this URL,
    # note the trailing slash strips out the /proxy path on
    # the request to the upstream server

    proxy_pass ${NGINX__EPIC__PROXY__PUBLIC};

    # Ensure HTTP get passed thru
    proxy_pass_request_headers on;

    # its helpful to cache these responses
    proxy_cache globalcache;

    # Deploy-time configurable
    ${HTTP_BASIC2}
  }

  # Redirect SSD fact sheet
  location = /api/public/document/673fa39fe2d737002260aaef/download/Fact_Sheet_PRGT_Substantial-Start-Determination.pdf {
    return 301 https://www2.gov.bc.ca/assets/download/F3F5FA681ADD4912B19A8DE62CBB451E;
  }

  # Redirect legacy /api/analytics path used by cached env.js (pre-v2.4.1)
  location = /api/analytics {
    limit_req zone=analytics burst=30 nodelay;
    proxy_pass ${NGINX__EPIC__PROXY__ANALYTICS}/analytics;
    proxy_http_version 1.1;
    proxy_pass_request_headers on;
    proxy_connect_timeout 5s;
    proxy_send_timeout 10s;
    proxy_read_timeout 10s;
  }

  # Analytics API - proxies to penguin-analytics service
  # Used by eagle-public and eagle-admin for anonymous usage tracking
  location /analytics {
    limit_req zone=analytics burst=30 nodelay;
    proxy_pass ${NGINX__EPIC__PROXY__ANALYTICS}/analytics;
    proxy_http_version 1.1;
    proxy_pass_request_headers on;
    proxy_connect_timeout 5s;
    proxy_send_timeout 10s;
    proxy_read_timeout 10s;
  }

  # Runtime configuration for frontend apps
  # Served from ConfigMap - edit via 'oc edit configmap rproxy-config' for instant changes
  # Frontends fetch this on startup to get environment-specific settings
  location = /api/config {
    alias /etc/nginx/config/config.json;
    default_type application/json;
    add_header Cache-Control "no-cache, no-store, must-revalidate";
    add_header Access-Control-Allow-Origin "*";
  }

  # Typesense search proxy — tighter rate limit than general /api (queries are CPU/RAM intensive).
  # ^~ prefix gives priority over the prefix /api location below so Typesense
  # requests are counted against the search zone, not the general API zone.
  location ^~ /api/public/typesense {
    limit_req zone=api_search burst=20 nodelay;
    proxy_pass ${NGINX__EPIC__PROXY__API};
    proxy_pass_request_headers on;
    proxy_cache globalcache;
    proxy_cache_bypass $http_authorization;
    proxy_no_cache $http_authorization;
    proxy_connect_timeout 10s;
    proxy_send_timeout    120s;
    proxy_read_timeout    120s;
  }

  location ^~ /api/typesense {
    limit_req zone=api_search burst=20 nodelay;
    proxy_pass ${NGINX__EPIC__PROXY__API};
    proxy_pass_request_headers on;
    proxy_cache globalcache;
    proxy_cache_bypass $http_authorization;
    proxy_no_cache $http_authorization;
    proxy_connect_timeout 10s;
    proxy_send_timeout    120s;
    proxy_read_timeout    120s;
  }

  location /api {
    # proxy all traffic to this URL,
    # note the trailing slash strips out the /proxy path on
    # the request to the upstream server

    proxy_pass ${NGINX__EPIC__PROXY__API};

    # Ensure HTTP get passed thru
    proxy_pass_request_headers on;
    limit_req zone=api_general burst=50 nodelay;

    # Cache public (unauthenticated) API responses only.
    # Authenticated requests bypass cache — admin users need fresh data
    # after mutations (delete, publish, etc.).
    proxy_cache globalcache;
    proxy_cache_bypass $http_authorization;
    proxy_no_cache $http_authorization;

    # Explicit timeouts — must be lower than HAProxy route timeout (180s)
    # so nginx fails first with a clean error rather than a generic 504.
    # 120s gives headroom for large document uploads and slow aggregations.
    proxy_connect_timeout 10s;
    proxy_send_timeout    120s;
    proxy_read_timeout    120s;
  }

  # Redirect /admin to /admin/ to avoid port exposure in redirects
  location = /admin {
    return 301 $scheme://$host/admin/;
  }

  location /admin/ {
    # proxy all traffic to this URL,
    # note the trailing slash strips out the /proxy path on
    # the request to the upstream server

    proxy_pass ${NGINX__EPIC__PROXY__ADMIN};

    # Ensure HTTP get passed thru
    proxy_pass_request_headers on;

    # its helpful to cache these responses
    proxy_cache globalcache;
  }

  # For e-guide service
  location /eguide {
    proxy_pass ${NGINX__EPIC__PROXY__EGUIDE};

    # Ensure HTTP get passed thru
    proxy_pass_request_headers on;

    # its helpful to cache these responses
    proxy_cache globalcache;

    ${HTTP_BASIC1}
  }

#  location /.well-known/acme-challenge {
#    proxy_pass ${NGINX__EPIC__PROXY__CERTBOT};
#
#    # Ensure HTTP get passed thru
#    proxy_pass_request_headers on;
#
#    # its helpful to cache these responses
#    proxy_cache globalcache;
#  }

  # Cache the lib directory
  location /lib {
    proxy_pass ${NGINX__EPIC__PROXY__ROOT};
    proxy_cache   globalcache;
  }

  # For status of ngnix service
  location /nginx_status {
    # Enable Nginx stats
    stub_status on;
    # Allow access from Kubernetes pods (10.0.0.0/8 covers OpenShift SDN)
    allow 10.0.0.0/8;
    # Allow localhost
    allow 127.0.0.1;
    # Other requests should be denied
    deny all;
    # No need to log this request, its just noise
    access_log off;
  }
}
